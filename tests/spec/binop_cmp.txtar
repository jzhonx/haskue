lt_f4: false
lt_f5: true
lt_f6: true
lt_f7: true
lt_m0: true
lt_m1: false
lt_m2: false
lt_m3: false
lt_m4: true
lt_m5: true
lt_s0: true
lt_s1: false
lt_s2: false
lt_s3: true
lt_s4: false
lt_s5: true
lt_s6: true
lt_s7: true
