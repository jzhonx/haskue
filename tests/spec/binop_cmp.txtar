-- cmp_match --
// Regex matching with =~
rm0: "Wild cats" =~ "cat"
rm1: "Wild cats" =~ "dog"
rm2: "foo" =~ "^[a-z]{3}$"
rm3: "foo" =~ "^[a-z]{4}$"
rm4: "hello" =~ "^h"
rm5: "hello" =~ "o$"
rm6: "hello" =~ "ell"
rm7: "123" =~ "[0-9]+"
rm8: "hello world" =~ "world"
rm9: "abc" =~ "abc"
rm10: "abc" =~ "^abc$"
rm11: "abc" =~ "b"
rm12: "abc" =~ "."
rm13: "abc" =~ "^."
rm14: "a" =~ "a"
rm15: "a" =~ "b"
-- exp_cmp_match --
rm0: true
rm1: false
rm2: true
rm3: false
rm4: true
rm5: true
rm6: true
rm7: true
rm8: true
rm9: true
rm10: true
rm11: true
rm12: true
rm13: true
rm14: true
rm15: false

