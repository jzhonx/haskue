-- binop_cmp1 --
i0: 1 == 2
i1: 2 == 2
i2: 2 == 1

f0: 1.0 == 2.0
f1: 2.0 == 2.0
f2: 2.0 == 1.0
f3: 2.0 == 2
f4: 2 == 2.0
f5: 1 == 2.0

b0: true == false
b1: true == true
b2: false == true

s0: "a" == "b"
s1: "a" == "a"
s2: "b" == "a"

n0: null == null
n1: null == "a"
n2: "a" == null
n3: null == {}
n4: {} == null
n5: null == (*1 | 2)
n6: (*1 | 2) == null

d1: (1 | 2) == _|_
d2: (1 | 2) != _|_
-- exp --
i0: false
i1: true
i2: false
f0: false
f1: true
f2: false
f3: true
f4: true
f5: false
b0: false
b1: true
b2: false
s0: false
s1: true
s2: false
n0: true
n1: false
n2: false
n3: false
n4: false
n5: false
n6: false
d1: false
d2: true

-- binop_cmp2 --
i0: 1 != 2
i1: 2 != 2
i2: 2 != 1

b0: true != false
b1: true != true
b2: false != true

s0: "a" != "b"
s1: "a" != "a"
s2: "b" != "a"

n0: null != null
n1: null != "a"
n2: "a" != null
n3: null != {}
n4: {} != null
n5: null != (*1 | 2)
n6: (*1 | 2) != null
-- exp --
i0: true
i1: false
i2: true
b0: true
b1: false
b2: true
s0: true
s1: false
s2: true
n0: false
n1: true
n2: true
n3: true
n4: true
n5: true
n6: true

-- binop_cmp3 --
i0: 1 < 2
i1: 2 <= 2
i2: 1 > 2
i3: 1 >= 2

-- exp --
i0: true
i1: true
i2: false
i3: false

-- cmp_lt --
// Less-than: integers
lt_i0: 1 < 2
lt_i1: 2 < 1
lt_i2: 2 < 2
lt_i3: 0 < 0
lt_i4: -1 < 0
lt_i5: -5 < -3
lt_i6: -3 < -5
lt_i7: -100 < -200
lt_i8: 1000 < 2000
// Less-than: floats
lt_f0: 1.0 < 2.0
lt_f1: 2.0 < 1.0
lt_f2: 2.0 < 2.0
lt_f3: 1.5 < 2.5
lt_f4: 2.5 < 1.5
lt_f5: 0.1 < 0.2
lt_f6: -1.0 < 0.0
lt_f7: -3.0 < -1.0
// Less-than: mixed int/float
lt_m0: 1 < 2.0
lt_m1: 2.0 < 1
lt_m2: 2 < 2.0
lt_m3: 2.0 < 2
lt_m4: -1 < 0.0
lt_m5: 0.0 < 1
// Less-than: strings
lt_s0: "a" < "b"
lt_s1: "b" < "a"
lt_s2: "a" < "a"
lt_s3: "aa" < "ab"
lt_s4: "ab" < "aa"
lt_s5: "hello" < "world"
lt_s6: "A" < "a"
lt_s7: "" < "a"
lt_s8: "a" < ""
// Less-than: bytes
// lt_b0: 'a' < 'b'
// lt_b1: 'b' < 'a'
// lt_b2: 'a' < 'a'
// lt_b0: true
// lt_b1: false
// lt_b2: false
-- exp_cmp_lt --
lt_i0: true
lt_i1: false
lt_i2: false
lt_i3: false
lt_i4: true
lt_i5: true
lt_i6: false
lt_i7: false
lt_i8: true
lt_f0: true
