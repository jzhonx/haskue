rn6: "hello" !~ "ell"
rn7: "123" !~ "[0-9]+"
rn8: "hello world" !~ "world"
rn9: "abc" !~ "abc"
rn10: "abc" !~ "^abc$"
rn11: "abc" !~ "b"
rn12: "a" !~ "a"
rn13: "a" !~ "b"
-- exp_cmp_not_match --
rn0: false
rn1: true
rn2: false
rn3: true
rn4: false
rn5: false
rn6: false
rn7: false
rn8: false
rn9: false
rn10: false
rn11: false
rn12: false
