-- cmp_eq_list --
a: [1,2] == [1,2]
-- exp --
a: true

-- cmp_err_struct --
a: {} == {}
-- exp --
a: true

-- cmp_cross_eq --
a: 1 == "a"
-- exp --
a: false

-- cmp_err_bool_ord --
a: true < false
-- exp --
error: invalid operands true and false to '<' (type bool and bool):
	-:1:4
	-:1:11

-- cmp_err_null_ord --
a: null < 1
-- exp --
error: invalid operands null and 1 to '<' (type null and int):
	-:1:4
	-:1:11

